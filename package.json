{
  "name": "lost-last-docs-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:sources": "node scripts/generate-sources.mjs",
    "prepare:content": "node scripts/prepare-content.mjs",
    "start": "npm run prepare:content && docusaurus start --host 0.0.0.0",
    "build": "npm run prepare:content && docusaurus build --out-dir docs",
    "serve": "docusaurus serve --host 0.0.0.0",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "uuid": "11.1.1"
  }
}
